{
  "name": "drone-rf-sim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4180 --strictPort",
    "verify": "npm run build && node scripts/verify.mjs",
    "verify:propagation": "node scripts/verify-propagation.mjs",
    "verify:rf": "node scripts/verify-rf-integration.mjs",
    "record": "npm run build && node scripts/record.mjs"
  },
  "dependencies": {
    "cesium": "^1.120.0",
    "playcanvas": "^2.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.49.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vite-plugin-static-copy": "^2.2.0"
  }
}
